# Kiroku — Environment Variables
# Copy this file to .env.local and fill in the values.
#   cp .env.example .env.local

# Backend API base URL (must be reachable from the browser)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Show demo content when the API is unreachable
NEXT_PUBLIC_USE_DEMO_DATA=true

# Telegram bot username for the login widget
NEXT_PUBLIC_TELEGRAM_BOT_NAME=

# Enable dev login (username-only, no auth provider)
NEXT_PUBLIC_ENABLE_DEV_LOGIN=true

# Enable Google OAuth login
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false

# Canonical site URL (used for og:image / opengraph metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Root domain for subdomain routing (username.example.com → /u/username)
NEXT_PUBLIC_ROOT_DOMAIN=localhost
