# ─── Kiroku Frontend ─── Local Development ──────────────────────────
# Copy this file to .env.local and fill in the values.
# cp .env.example .env.local
# ──────────────────────────────────────────────────────────────────────

# Backend API base URL (default: http://localhost:3000)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Enable demo data when API is unavailable (true/false)
NEXT_PUBLIC_USE_DEMO_DATA=true

# Telegram bot username for the login widget
NEXT_PUBLIC_TELEGRAM_BOT_NAME=

# Enable dev login form that bypasses Telegram (true/false)
NEXT_PUBLIC_ENABLE_DEV_LOGIN=true

# Canonical site URL (used for Open Graph metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Root domain for subdomain routing (username.kiroku.com -> /u/username)
NEXT_PUBLIC_ROOT_DOMAIN=localhost
